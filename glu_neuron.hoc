begintemplate glutamatergic
public init, topol, basic_shape, subsets, geom, biophys, geom_nseg, biophys_inhomo
public synlist, x, y, z, position, connect2target

public soma, dend, axon, apic
public all, somatic, axonal, basal, apical

objref synlist

proc init() {
  topol()
  subsets()
  geom()
  biophys()
  geom_nseg()
  synlist = new List()
  position(-1000, -1000, -1000)
  synapses()
}

create soma, dend[19], axon, apic[35]

proc topol() { local i
  connect dend(0), soma(0)
  for i = 1, 2 connect dend[i](0), dend(1)
  connect dend[3](0), soma(0)
  for i = 4, 5 connect dend[i](0), dend[i-1](1)
  connect dend[6](0), dend[4](1)
  connect dend[7](0), dend[3](1)
  for i = 8, 9 connect dend[i](0), dend[7](1)
  for i = 10, 11 connect dend[i](0), dend[9](1)
  connect dend[12](0), soma(0)
  for i = 13, 14 connect dend[i](0), dend[i-1](1)
  connect dend[15](0), dend[13](1)
  connect dend[16](0), dend[12](1)
  for i = 17, 18 connect dend[i](0), dend[16](1)
  connect axon(0), soma(0)
  connect apic(0), soma(0)
  for i = 1, 9 connect apic[i](0), apic[i-1](1)
  connect apic[10](0), apic[8](1)
  for i = 11, 14 connect apic[i](0), apic[i-1](1)
  connect apic[15](0), apic[13](1)
  for i = 16, 18 connect apic[i](0), apic[i-1](1)
  connect apic[19](0), apic[17](1)
  connect apic[20](0), apic[16](1)
  connect apic[21](0), apic[15](1)
  connect apic[22](0), apic[12](1)
  connect apic[23](0), apic[11](1)
  connect apic[24](0), apic[10](1)
  connect apic[25](0), apic[7](1)
  connect apic[26](0), apic[6](1)
  connect apic[27](0), apic[5](1)
  connect apic[28](0), apic[4](1)
  connect apic[29](0), apic[3](1)
  connect apic[30](0), apic[2](1)
  connect apic[31](0), apic[1](1)
  for i = 32, 33 connect apic[i](0), apic[31](1)
  connect apic[34](0), apic(1)
  basic_shape()
}
