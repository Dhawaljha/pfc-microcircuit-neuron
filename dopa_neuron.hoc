objref all, somatic, axonal, basal
proc subsets() { local i
  objref all, somatic, axonal, basal
  all = new SectionList()
    soma all.append()
    for i=0, 15 dend[i] all.append()
    axon all.append()

  somatic = new SectionList()
    soma somatic.append()

  axonal = new SectionList()
    axon axonal.append()

  basal = new SectionList()
    for i=0, 15 dend[i] basal.append()

}
proc geom() {
  forsec all {  }
}

func lambda_f() { local i, x1, x2, d1, d2, lam
        if (n3d() < 2) {
                return 1e5*sqrt(diam/(4*PI*$1*Ra*cm))
        }
// above was too inaccurate with large variation in 3d diameter
// so now we use all 3-d points to get a better approximate lambda
        x1 = arc3d(0)
        d1 = diam3d(0)
        lam = 0
        for i=1, n3d()-1 {
                x2 = arc3d(i)
                d2 = diam3d(i)
                lam += (x2 - x1)/sqrt(d1 + d2)
                x1 = x2   d1 = d2
        }
        //  length of the section in units of lambda
        lam *= sqrt(2) * 1e-5*sqrt(4*PI*$1*Ra*cm)

        return L/lam
}


proc geom_nseg() {
  forsec all { nseg = int((L/(0.1*lambda_f(100))+.999)/2)*2 + 1  }
}
proc biophys() {
  forsec all {
    Ri = 45
    cm = 1
  }
  soma{ 
   insert nattxs
   gbar_nattxs = 0.5

   insert nattxr
   gbar_nattxr = 0.008

   insert kdr
   gkdrbar_kdr = 0.2

   insert cachan
   gcalbar_cachan = 0.8e-02
   gcatbar_cachan = 1e-03
   gcanbar_cachan = 1.71e-04
   
   insert cad
   taur_cad = 15
   insert capump
   icapumpmax_capump  = 0.15

   insert pump
