begintemplate dopaminergic
public init, topol, basic_shape, subsets, geom, biophys, geom_nseg, biophys_inhomo
public synlist, x, y, z, position, connect2target

public soma, dend, axon
public all, somatic, axonal, basal

objref synlist

proc init() {
  topol()
  subsets()
  geom()
  biophys()
  geom_nseg()
  synlist = new List()
  position(1000, 1000, 1000)
  synapses()
}

create soma, dend[16], axon

proc topol() { local i
  connect dend(0), soma(0.5)
  for i = 1, 2 connect dend[i](0), dend(1)
  for i = 3, 4 connect dend[i](0), dend[2](1)
  connect dend[5](0), soma(0.5)
  for i = 6, 7 connect dend[i](0), dend[5](1)
  connect dend[8](0), soma(0.5)
  for i = 9, 10 connect dend[i](0), dend[i-1](1)
  connect dend[11](0), dend[9](1)
  connect dend[12](0), dend[8](1)
  connect dend[13](0), soma(0.5)
  for i = 14, 15 connect dend[i](0), dend[13](1)
  connect axon(0), soma(0.5)
  basic_shape()
}
